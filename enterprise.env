# ═══════════════════════════════════════════════════
#  REGIME LOCUS MATRIX — Enterprise host (.env template)
#  Copy to /opt/enterprise/config/.env on the VPS (chmod 600). Do not commit real tokens.
# ═══════════════════════════════════════════════════

# ── Repo ────────────────────────────────────────────
REPO_DIR=/opt/Regime-Locus-Matrix
VENV=/opt/Regime-Locus-Matrix/venv

# ── Ollama ──────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
SCOTTY_MODEL=llama3.2:3b
SPOCK_MODEL=qwen2.5:7b

# ── Telegram (host watchdog alerts — NOT the Hermes crew bot unless you reuse tokens) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Host watchdog (systemd unit: scotty.service — scripts/rlm_enterprise_watchdog.py) ──
SCOTTY_POLL_SECONDS=60
SCOTTY_LOG=/var/log/enterprise/scotty.log
CPU_WARN_PCT=80
RAM_WARN_PCT=85
DISK_WARN_PCT=75

# Same interpreters gather_health_report uses when SCOTTY_RLM_HEALTH=1
RLM_ROOT=/opt/Regime-Locus-Matrix
RLM_HEALTH_PYTHON=/opt/rlm-venv/bin/python
SCOTTY_RLM_HEALTH=0

# systemd base names — must match loaded units on THIS host.
WATCHED_SERVICES=ollama,rlm-systems-control-telegram,rlm-master-trader,regime-locus-crew

# ── Offline Ollama advisory (NOT ROEE; NOT Hermes — experiments only) ───────────
SPOCK_TIMEOUT_SECONDS=180
SPOCK_MIN_CONFIDENCE=0.65
SPOCK_ENABLED=false
SPOCK_OVERRIDE_KEY=

# ── Kirk hook decision log ─────────────────────────────────────────────────────
DECISION_LOG=/opt/enterprise/data/decisions.jsonl
