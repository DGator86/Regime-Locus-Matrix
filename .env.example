# Copy to .env and fill in ( .env is gitignored )

# Cap BLAS/OpenMP + PyTorch threads for forecast / universe / Streamlit on shared VPS (optional).
# RLM_MAX_CPU_THREADS=2

# Telegram — two-bot layout (one HTTP long-poll client per token; never share a token across processes)
#
# Legacy single bot (scripts/rlm_telegram_bot.py) — prefer migrating to split bots below.
# TELEGRAM_BOT_TOKEN=
#
# RLM Systems Control — health / allowlisted repairs / escalate to you (separate @BotFather bot)
# RLM_SYSTEMS_CONTROL_TELEGRAM_BOT_TOKEN=
# RLM_SYSTEMS_CONTROL_TELEGRAM_CHAT_ID=
# RLM_SYSTEMS_CONTROL_TELEGRAM_ALLOWED_USER_IDS=
#
# Hermes crew / analyst channel — separate bot from Systems Control
# RLM_HERMES_TELEGRAM_BOT_TOKEN=
# RLM_HERMES_TELEGRAM_CHAT_ID=
# RLM_HERMES_TELEGRAM_ALLOWED_USER_IDS=
#
# If a token is ever exposed (chat, screenshot, repo), revoke it in @BotFather and set the new value only in .env
# Optional: comma-separated numeric user IDs; if set, other users get "Not authorized"
# TELEGRAM_ALLOWED_USER_IDS=
# Shorter long-poll (0-50) if Windows/firewall drops connections: e.g. TELEGRAM_LONG_POLL_SEC=10
# TELEGRAM_LONG_POLL_SEC=
# File-driven push (options plan + trade_log + equity state) — 0 to disable
# TELEGRAM_NOTIFY=1
# Your numeric chat id, or set via /start in the bot (also used by scripts/run_crew.py / regime-locus-crew)
# TELEGRAM_NOTIFY_CHAT_ID=
# TELEGRAM_NOTIFY_INTERVAL_SEC=20

# ─────────────────────────────────────────────────────────────────────────────
# Hermes AI crew (regime-locus-crew service / scripts/run_crew.py)
# Choose ONE backend.
#
# Option A — Groq cloud (free tier; fastest on VPS without GPU):
#   Get your free key at https://console.groq.com
#   When GROQ_API_KEY is set, the crew auto-uses api.groq.com without any other
#   RLM_HERMES_* vars needed.
# GROQ_API_KEY=gsk_...
# RLM_HERMES_MODEL=llama-3.3-70b-versatile   # optional; auto-default when using Groq
#
# Option B — local Ollama:
# RLM_HERMES_BASE_URL=http://127.0.0.1:11434/v1
# RLM_HERMES_API_KEY=ollama
# RLM_HERMES_MODEL=llama3.2
#
# Other tuning (optional):
# RLM_HERMES_MAX_ITERATIONS=20
# RLM_HERMES_SKIP_MEMORY=1        # disable Hermes persistent memory (headless VPS)
# ─────────────────────────────────────────────────────────────────────────────

MASSIVE_API_KEY=

# Massive Flat Files (S3) — bulk historical options CSV.gz; separate from MASSIVE_API_KEY
# MASSIVE_S3_ENDPOINT=
# MASSIVE_S3_ACCESS_KEY=
# MASSIVE_S3_SECRET_KEY=
# MASSIVE_S3_BUCKET=flatfiles
# MASSIVE_S3_REGION=us-east-1
# MASSIVE_FLATFILES_KEY_STYLE=year_month_date
# MASSIVE_FLATFILES_PREFIX_TRADES=
# MASSIVE_FLATFILES_PREFIX_QUOTES=
# MASSIVE_FLATFILES_PREFIX_DAY_AGGS=
# MASSIVE_FLATFILES_PREFIX_MINUTE_AGGS=

# Interactive Brokers — stocks / historical bars / option combo orders (TWS or IB Gateway; API enabled)
# IBKR_HOST=127.0.0.1
# Paper TWS 7497, live TWS 7496; Gateway paper 4002, live 4001
# VPS: gnzsnz ib-gateway-docker + host networking / socat often exposes paper API on 4004 — set IBKR_PORT=4004.
# Automated paper trading requires a PAPER port (7497, 4002, or 4004).
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
# Optional separate API session for order scripts (avoids clashing with charts on clientId 1)
# IBKR_ORDER_CLIENT_ID=2

# ─────────────────────────────────────────────────────────────────────────────
# TradingAgents multi-agent LLM pipeline (pip install -e ".[trading_agents]")
# Adds rlm_get_trading_agents_analysis tool to the Hermes crew.
# An Analyst Team, Bull/Bear researcher debate, Trader agent, Risk Management
# debate, and Portfolio Manager run for a given ticker and return BUY/HOLD/SELL.
#
# PROVIDER AUTO-DETECTION (no TRADING_AGENTS_LLM_PROVIDER needed):
# The adapter picks the first available key in this priority order:
#
#   1. Groq (FREE) — reuses your existing GROQ_API_KEY from the Hermes crew.
#      Models: llama-3.3-70b-versatile (deep) + llama-3.1-8b-instant (quick).
#      No extra setup if GROQ_API_KEY is already set above.
#
#   2. Google Gemini (FREE) — free tier via Google AI Studio (aistudio.google.com).
#      GOOGLE_API_KEY=AIza...
#      Models: gemini-2.0-flash for both deep and quick.
#
#   3. OpenRouter (FREE tier) — free-tier models via openrouter.ai.
#      OPENROUTER_API_KEY=sk-or-...
#      Models: meta-llama/llama-4-maverick:free + google/gemini-2.0-flash-exp:free
#
#   4. Anthropic — paid; used as fallback if ANTHROPIC_API_KEY is set.
#   5. OpenAI   — paid; used as last resort if OPENAI_API_KEY is set.
#
# MANUAL OVERRIDE (bypasses auto-detection entirely):
# TRADING_AGENTS_LLM_PROVIDER=openai        # openai / google / openrouter / anthropic
# TRADING_AGENTS_DEEP_THINK_LLM=llama-3.3-70b-versatile
# TRADING_AGENTS_QUICK_THINK_LLM=llama-3.1-8b-instant
# TRADING_AGENTS_BACKEND_URL=https://api.groq.com/openai/v1   # custom OpenAI-compat endpoint
#
# Analyst configuration:
# TRADING_AGENTS_ANALYSTS=market,news,fundamentals   # comma-separated; add "social" for sentiment
# TRADING_AGENTS_MAX_DEBATE_ROUNDS=1                 # bull/bear researcher debate iterations
# TRADING_AGENTS_MAX_RISK_ROUNDS=1                   # risk management debate iterations
#
# Optional features:
# TRADING_AGENTS_ONLINE_TOOLS=0                      # 1 to enable web-search tools (requires keys)
# TRADING_AGENTS_CHECKPOINT=0                        # 1 to persist LangGraph state to SQLite
# ─────────────────────────────────────────────────────────────────────────────
