# Copy to .env and fill in ( .env is gitignored )

# Cap BLAS/OpenMP + PyTorch threads for forecast / universe / Streamlit on shared VPS (optional).
# RLM_MAX_CPU_THREADS=2

# Telegram — scripts/rlm_telegram_bot.py (token from @BotFather; never commit the real value)
# TELEGRAM_BOT_TOKEN=
# Optional: comma-separated numeric user IDs; if set, other users get "Not authorized"
# TELEGRAM_ALLOWED_USER_IDS=
# Shorter long-poll (0-50) if Windows/firewall drops connections: e.g. TELEGRAM_LONG_POLL_SEC=10
# TELEGRAM_LONG_POLL_SEC=
# File-driven push (options plan + trade_log + equity state) — 0 to disable
# TELEGRAM_NOTIFY=1
# Your numeric chat id, or set via /start in the bot
# TELEGRAM_NOTIFY_CHAT_ID=
# TELEGRAM_NOTIFY_INTERVAL_SEC=20

MASSIVE_API_KEY=

# Massive Flat Files (S3) — bulk historical options CSV.gz; separate from MASSIVE_API_KEY
# MASSIVE_S3_ENDPOINT=
# MASSIVE_S3_ACCESS_KEY=
# MASSIVE_S3_SECRET_KEY=
# MASSIVE_S3_BUCKET=flatfiles
# MASSIVE_S3_REGION=us-east-1
# MASSIVE_FLATFILES_KEY_STYLE=year_month_date
# MASSIVE_FLATFILES_PREFIX_TRADES=
# MASSIVE_FLATFILES_PREFIX_QUOTES=
# MASSIVE_FLATFILES_PREFIX_DAY_AGGS=
# MASSIVE_FLATFILES_PREFIX_MINUTE_AGGS=

# Interactive Brokers — stocks / historical bars / option combo orders (TWS or IB Gateway; API enabled)
# IBKR_HOST=127.0.0.1
# Paper TWS 7497, live TWS 7496; Gateway paper 4002, live 4001
# VPS: gnzsnz ib-gateway-docker + host networking / socat often exposes paper API on 4004 — set IBKR_PORT=4004.
# Automated paper trading requires a PAPER port (7497, 4002, or 4004).
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
# Optional separate API session for order scripts (avoids clashing with charts on clientId 1)
# IBKR_ORDER_CLIENT_ID=2
