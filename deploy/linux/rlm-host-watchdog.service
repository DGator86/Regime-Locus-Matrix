# VPS / canonical Hostinger layout:
#   Repo: /opt/Regime-Locus-Matrix  |  venv: /opt/rlm-venv
# Optional Telegram + tuning: /opt/enterprise/config/.env (loaded by the script by default).
#
#   sudo cp deploy/linux/rlm-host-watchdog.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now rlm-host-watchdog

[Unit]
Description=RLM host watchdog (systemd + resources + optional Telegram; Hermes crew is separate)
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/Regime-Locus-Matrix
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/opt/Regime-Locus-Matrix/.env
ExecStart=/opt/rlm-venv/bin/python3 /opt/Regime-Locus-Matrix/scripts/rlm_enterprise_watchdog.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rlm-host-watchdog

[Install]
WantedBy=multi-user.target
