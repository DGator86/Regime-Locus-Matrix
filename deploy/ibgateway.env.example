# Copy beside `ib-gateway-compose.example.yml` as `.env.ibgateway` (or path in compose).
#   cp deploy/ibgateway.env.example /docker/ib-gateway/.env.ibgateway && chmod 600 .../.env.ibgateway
# Fill secrets locally; never commit the real file.

TWS_USERID=
TWS_PASSWORD=
TRADING_MODE=paper

# Optional (unattended / image-specific; see gnzsnz/ib-gateway-docker)
# BYPASS_WARNING=yes
# TWOFA_TIMEOUT_ACTION=restart
# VNC_SERVER_PASSWORD=
