# Copy to /etc/systemd/system/rlm-master-trader.service, adjust paths if needed.
# First-time PDT challenge: cd repo && rlm challenge --reset --symbol SPY
# Then: systemctl daemon-reload && systemctl enable --now rlm-master-trader
#
# Enable exactly ONE master trading loop: this unit OR regime-locus-master.service OR
# rlm-master-telegram.service (mutual Conflicts).

[Unit]
Description=RLM Master Trader (Options dry-run + Equity paper + PDT challenge)
Conflicts=regime-locus-master.service rlm-master-telegram.service
After=network-online.target docker.service ib-gateway.service
Wants=network-online.target docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/Regime-Locus-Matrix
EnvironmentFile=/opt/Regime-Locus-Matrix/.env
Environment=PATH=/opt/rlm-venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/opt/rlm-venv/bin/python scripts/run_everything.py --master --with-equity --equity-use-account-scale --with-challenge
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
