# Copy to `.env.local` in this folder (loaded by Next.js).
# Point at the folder that contains forecast_features_SPY.csv, universe_trade_plans.json, etc.

# Windows (repo Regime-Locus-Matrix): path relative to `dashboard/` or use an absolute path
RLM_DATA_DIR=../data/processed

# Or align with Python (data/processed under the same root as data/raw):
# RLM_DATA_ROOT=../data

# Linux / VPS (usually set by PM2 in deploy_dashboard.ps1):
# RLM_DATA_DIR=/opt/Regime-Locus-Matrix/data/processed
