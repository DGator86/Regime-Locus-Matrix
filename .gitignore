# Data artifacts
data/stocks/
data/options/

# Bare (no-symbol) backtest output — symbol-specific files are canonical
data/processed/backtest_equity.csv
# Runtime outputs in data/processed are intentionally untracked to prevent
# deploy-time merge conflicts across hosts. Keep only promoted config below.

# Keep gitkeep sentinels; ignore everything else under data/ subdirs
data/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/live_regime_model.json
!data/processed/live_nightly_hyperparams.json
!data/processed/regime_transition_calibration.json
!data/challenge/.gitkeep

# Model / experiment artifacts
artifacts/
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors

# Common generated formats
*.parquet
*.feather
*.csv
*.json
!data/processed/live_regime_model.json
!data/processed/live_nightly_hyperparams.json
!data/processed/regime_transition_calibration.json
!dashboard/package.json
!dashboard/tsconfig.json
!market-field-navigator/frontend/package.json
!market-field-navigator/frontend/package-lock.json
!market-field-navigator/frontend/tsconfig.json
!configs/*.json
!configs/*.yaml

# Versioned test fixtures and sample data are explicitly allowed.
# Runtime outputs must live under ignored data/ or artifacts/ roots — never here.
!tests/fixtures/**
!sample_data/**

# Streamlit
.streamlit/secrets.toml

# Backup junk
_rebase_abort_backup/

